---
interface ProjectLinks {
  github: string | null;
  demo: string | null;
  paper: string | null;
}

interface Props {
  title: string;
  description: string;
  image: string;
  tags: string[];
  links: ProjectLinks;
}

const { title, description, image, tags, links } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => `${baseUrl.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
---

<article class="overflow-hidden rounded-xl border border-[var(--color-border)] bg-white transition-all hover:-translate-y-0.5 hover:shadow-lg">
  <img
    src={withBase(image)}
    alt={title}
    loading="lazy"
    class="h-44 w-full object-cover sm:h-48"
  />

  <div class="p-5">
    <h3 class="mb-2 text-lg font-semibold text-[var(--color-primary)]">{title}</h3>
    <p class="mb-4 text-sm leading-relaxed text-[var(--color-text-secondary)]">{description}</p>

    <div class="mb-4 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="rounded-full bg-[var(--color-accent)]/10 px-2.5 py-1 text-xs font-medium text-[var(--color-accent-dark)]">
          {tag}
        </span>
      ))}
    </div>

    <div class="flex flex-wrap gap-2">
      {links.github && (
        <a
          href={links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 rounded border border-[var(--color-border)] px-2.5 py-1 text-xs font-medium text-[var(--color-text-secondary)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent-dark)] no-underline"
        >
          GitHub
        </a>
      )}
      {links.demo && (
        <a
          href={links.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 rounded border border-[var(--color-border)] px-2.5 py-1 text-xs font-medium text-[var(--color-text-secondary)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent-dark)] no-underline"
        >
          Demo
        </a>
      )}
      {links.paper && (
        <a
          href={links.paper}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 rounded border border-[var(--color-border)] px-2.5 py-1 text-xs font-medium text-[var(--color-text-secondary)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent-dark)] no-underline"
        >
          Paper
        </a>
      )}
    </div>
  </div>
</article>
