---
import profile from '../data/profile.json';
import SocialLinks from './SocialLinks.astro';
---

<div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 text-center">
  <img
    src={profile.photo}
    alt={profile.name}
    class="mx-auto mb-4 h-36 w-36 rounded-full border-4 border-[var(--color-accent)] object-cover shadow-md"
  />
  <h2 class="mb-1 text-xl font-bold text-[var(--color-primary)]">{profile.name}</h2>
  <p class="mb-1 text-sm font-medium text-[var(--color-text-secondary)]">{profile.title}</p>
  <p class="mb-4 text-sm text-[var(--color-text-secondary)]">{profile.affiliation}</p>

  <SocialLinks />

  <div class="mt-4 space-y-2 text-left text-sm text-[var(--color-text-secondary)]">
    <div class="flex items-start gap-2">
      <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      <span>{profile.email}</span>
    </div>
    <div class="flex items-start gap-2">
      <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      <span>{profile.phone}</span>
    </div>
    <div class="flex items-start gap-2">
      <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <span>{profile.address}</span>
    </div>
  </div>

  {profile.quote && (
    <p class="mt-4 border-t border-[var(--color-border)] pt-4 text-xs italic text-[var(--color-text-secondary)]">
      "{profile.quote}"
    </p>
  )}
</div>
