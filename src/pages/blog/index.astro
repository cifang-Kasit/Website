---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import profile from '../../data/profile.json';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<PageLayout title={`${profile.name} - Blog`} description="Notes on research, engineering, and learning">
  <h1 class="mb-4 text-2xl font-bold text-[var(--color-primary)]">Blog</h1>
  <p class="mb-8 max-w-3xl leading-relaxed text-[var(--color-text-secondary)]">
    I write short notes about research ideas, engineering practices, and lessons from building
    systems in academia and industry.
  </p>

  <div class="space-y-4">
    {posts.map((post) => (
      <BlogPostCard
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
        readTime={post.data.readTime}
        href={`/blog/${post.slug}/`}
      />
    ))}
  </div>
</PageLayout>
